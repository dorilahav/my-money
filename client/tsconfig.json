{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react",
    "moduleResolution": "node",
    "removeComments": true,
    "baseUrl": ".",
    "paths": {
      "@components": [
        "./src/components"
      ],
      "@hooks": [
        "./src/hooks"
      ],
      "@services": [
        "./src/services"
      ],
      "@common": [
        "../common"
      ]
    }
  }
}