{
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react",
    "module": "es6",
    "moduleResolution": "node",
    "removeComments": true,
    "baseUrl": ".",
    "paths": {
      "@components": [
        "./src/app/components"
      ],
      "@hooks": [
        "./src/app/hooks"
      ],
      "@theme": [
        "./src/app/theme"
      ]
    }
  }
}