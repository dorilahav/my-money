{
  "compilerOptions": {
    "target": "ESNext",
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "es6",
    "moduleResolution": "node",
    "removeComments": true,
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    "baseUrl": ".",
    "paths": {
      "express": [
        "./types/express.d.ts"
      ],
      "express-serve-static-core": [
        "./types/express-serve-static-core.d.ts"
      ]
    }
  }
}